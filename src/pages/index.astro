---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Profile from '../components/Profile.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';

const profileData = {
	name: 'Ondrej Michal',
	title: 'Student',
	bio: 'Student. Code dabbler. Theme restorer. Firmware forker.',
	avatarUrl: 'https://avatars.githubusercontent.com/u/36997301?v=4&s=120',
};

const skills = ['HTML/CSS', 'Astro', 'Git', 'UI Design'];

const projects = [
	{
		title: 'Alexis Modern Discord theme fixes',
		description: 'My attempt to keep Alexis Modern Discord Theme alive.',
		url: 'https://github.com/onkofonko/onkofonko.github.io/tree/main/public/theme',
		ariaLabel: 'View Alexis Modern Discord theme fixes project',
	},
	{
		title: 'Padavan firmware fork',
		description: 'A customized fork of the Padavan router firmware.',
		url: 'https://github.com/onkofonko/padavan-ng',
		ariaLabel: 'View Padavan firmware fork project',
	},
];
---

<Layout title="Ondrej Michal's Site">
	<div class="container">
		<div class="profile-section gap-4">
			<Profile {...profileData} />
			<About bio={profileData.bio} />
		</div>
		<div class="skills-socials-section">
			<div class="left">
				<Skills skills={skills} />
				<SocialLinks />
			</div>
			<div class="right">
				<ProjectsGrid projects={projects} />
			</div>
		</div>
	</div>
</Layout>

<script src="../scripts/copytext.ts"></script>
